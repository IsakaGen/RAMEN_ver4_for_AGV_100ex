<!-- =================================================================================== -->
<robot name="agv">
  <!-- ロボット全体の質量 [kg] -->
  <!-- 左右車輪の中心間距離 30 cm -->
  <!-- 20 Hz -->
  <!-- マテリアル -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <!-- =====================
       本体リンク (base_link)
       ===================== -->
  <link name="base_link">
    <!-- ビジュアル (円柱) -->
    <visual>
      <geometry>
        <cylinder length="0.75" radius="0.2"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <!-- コリジョン (円柱) -->
    <collision>
      <geometry>
        <cylinder length="0.75" radius="0.2"/>
      </geometry>
    </collision>
    <!-- 慣性 (質量と慣性テンソル) -->
    <inertial>
      <mass value="10.0"/>
      <!-- 慣性テンソルは円柱慣性、単純に ixx=iyy= (1/12) m (3r^2 + h^2) 等でもよいが、ここでは近似値 -->
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <!-- =====================
       車輪リンク
       ===================== -->
  <!-- 左車輪リンク -->
  <link name="left_wheel_link">
    <!-- ビジュアル (車輪は黒い円柱) -->
    <visual>
      <geometry>
        <cylinder length="0.03" radius="0.065"/>
      </geometry>
      <material name="black"/>
    </visual>
    <!-- コリジョン -->
    <collision>
      <geometry>
        <cylinder length="0.03" radius="0.065"/>
      </geometry>
    </collision>
    <inertial>
      <!-- 車輪の慣性は小さくしても可 -->
      <mass value="1.0"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  <!-- 右車輪リンク -->
  <link name="right_wheel_link">
    <visual>
      <geometry>
        <cylinder length="0.03" radius="0.065"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.03" radius="0.065"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  <!-- =====================
       固定ジョイント (base_link ⇔ 車輪)
       ===================== -->
  <!-- 左車輪：回転ジョイントに変更 -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin rpy="0 0 1.5708" xyz="0 0.15 -0.31"/>
    <axis xyz="0 1 0"/>
    <limit effort="1.0" velocity="10.0"/>
  </joint>
  <!-- 右車輪：回転ジョイントに変更 -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin rpy="0 0 1.5708" xyz="0 -0.15 -0.31"/>
    <axis xyz="0 1 0"/>
    <limit effort="1.0" velocity="10.0"/>
  </joint>
  <!-- =====================
       LiDAR リンクと固定ジョイント
       ===================== -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.03"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <!-- X=0, Y=0, Z=lidar_height -->
    <origin rpy="0 0 0" xyz="0 0 0.1"/>
  </joint>
  <!-- =====================
       Gazebo プラグイン群
       ===================== -->
  <gazebo>
    <!-- 差動駆動プラグイン -->
    <plugin filename="libgazebo_ros_diff_drive.so" name="gazebo_ros_diff_drive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <!-- ホイール間隔はそのまま -->
      <wheel_separation>0.3</wheel_separation>
      <!-- 直径 (= 半径 × 2) を必ず渡す -->
      <wheel_diameter>0.13</wheel_diameter>
      <cmd_vel_timeout>0.5</cmd_vel_timeout>
      <topicName>/cmd_vel</topicName>
      <robotNamespace>agv</robotNamespace>
    </plugin>
    <!-- LiDAR プラグイン -->
 <gazebo reference="lidar_link">
  <sensor name="laser_sensor" type="ray">
    <pose>0 0 0 0 0 0</pose>
    <update_rate>20</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>360</samples>
          <resolution>1</resolution>
          <min_angle>-1.5708</min_angle>
          <max_angle>1.5708</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.05</min>
        <max>16.0</max>
        <resolution>0.01</resolution>
      </range>
    </ray>
    <plugin name="gazebo_ros_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
      <ros>
        <remapping>~/out:=/scan</remapping>
      </ros>
      <frameName>lidar_link</frameName>
    </plugin>
  </sensor>
 </gazebo>
</robot>
