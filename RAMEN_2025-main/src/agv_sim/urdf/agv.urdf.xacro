<?xml version="1.0"?>
<robot name="agv" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- =====================
       パラメータ
       ===================== -->
  <xacro:property name="body_radius"    value="0.2"/>
  <xacro:property name="body_height"    value="0.2"/>
  <xacro:property name="mass"           value="10.0"/>

  <xacro:property name="wheel_radius"      value="0.065"/>
  <xacro:property name="wheel_width"       value="0.03"/>
  <xacro:property name="wheel_separation"  value="0.3"/>
  <xacro:property name="use_gazebo" value="false"/>
  <!-- =====================
       マテリアル
       ===================== -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- =====================
       本体
       ===================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="${body_radius}" length="${body_height}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${body_radius}" length="${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

<xacro:if value="${use_gazebo}">
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
</xacro:if>

  <!-- =====================
       支柱リンク（共通）
       ===================== -->
  <xacro:macro name="pillar_link_macro" params="name">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="0.01" length="0.2"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.01" length="0.2"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- =====================
       支柱配置（5本）
       ===================== -->

  <!-- 北1 -->
  <xacro:pillar_link_macro name="pillar_link_north1"/>
  <joint name="pillar_joint_north" type="fixed">
    <parent link="base_link"/>
    <child link="pillar_link_north1"/>
    <origin xyz="0.1497 0.1087 ${body_height/2}" rpy="0 0 0"/>
  </joint>


  <!-- 北2 -->
  <xacro:pillar_link_macro name="pillar_link_north2"/>
  <joint name="pillar_joint_north2" type="fixed">
    <parent link="base_link"/>
    <child link="pillar_link_north2"/>
    <origin xyz="0.1497 -0.1087 ${body_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- 南 -->
  <xacro:pillar_link_macro name="pillar_link_south"/>
  <joint name="pillar_joint_south" type="fixed">
    <parent link="base_link"/>
    <child link="pillar_link_south"/>
    <origin xyz="0 -0.185 ${body_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- 東 -->
  <xacro:pillar_link_macro name="pillar_link_east"/>
  <joint name="pillar_joint_east" type="fixed">
    <parent link="base_link"/>
    <child link="pillar_link_east"/>
    <origin xyz="0 0.185 ${body_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- 西 -->
  <xacro:pillar_link_macro name="pillar_link_west"/>
  <joint name="pillar_joint_west" type="fixed">
    <parent link="base_link"/>
    <child link="pillar_link_west"/>
    <origin xyz="-0.185 0 ${body_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- =====================
       左右車輪
       ===================== -->
  <link name="left_wheel_link">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 1.5708 1.5708"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

<xacro:if value="${use_gazebo}">
  <gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
  </gazebo>
</xacro:if>

  <link name="right_wheel_link">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 1.5708 1.5708"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

<xacro:if value="${use_gazebo}">
  <gazebo reference="right_wheel_link">
    <material>Gazebo/Black</material>
  </gazebo>
</xacro:if>
  <!-- =====================
       ジョイント
       ===================== -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel_link"/>
    <origin xyz="-0.15 ${wheel_separation/2} ${-body_height/2}" rpy="0 1.5708 1.5708"/>
    <axis  xyz="0 0 1"/>
    <limit effort="1.0" velocity="10.0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel_link"/>
    <origin xyz="-0.15 ${-wheel_separation/2} ${-body_height/2}" rpy="0 1.5708 1.5708"/>
    <axis  xyz="0 0 1"/>
    <limit effort="1.0" velocity="10.0"/>
  </joint>

  <!-- =====================
       レーザー (LiDAR)
       ===================== -->
  <link name="laser_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.1"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
  </link>

<xacro:if value="${use_gazebo}">
  <gazebo reference="laser_link">
    <material>Gazebo/Black</material>
  </gazebo>
</xacro:if>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0 0 ${body_height/2+0.02}" rpy="0 0 3.1415926535"/>
  </joint>

  <!-- =====================
       Gazebo プラグイン
       ===================== -->
 
<xacro:if value="${use_gazebo}">
 <gazebo>
    <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${wheel_radius * 2.0}</wheel_diameter>
      <cmd_vel_timeout>0.5</cmd_vel_timeout>
      <topicName>/cmd_vel</topicName>
      <robotNamespace>agv</robotNamespace>
    </plugin>
  </gazebo>
</xacro:if>
  <!-- レーザーセンサ -->
<xacro:if value="${use_gazebo}">
  <gazebo reference="laser_link">
    <sensor name="laser_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>20</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
        <topicName>/scan</topicName>
          <ros>
            <topic>/scan</topic>
          </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_link</frame_name> 
      </plugin>
    </sensor>
  </gazebo>
</xacro:if>
  <!-- =====================
       キャスター（補助輪）
       ===================== -->
  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

<xacro:if value="${use_gazebo}">
  <gazebo reference="caster_link">
    <material>Gazebo/Black</material>
  </gazebo>
</xacro:if>

  <joint name="caster_joint" type="continuous">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="0.2 0 ${-body_height/2 - 0.03}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>
